generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectKind {
  draw
  logo
}

model Project {
  id        String      @id @default(cuid())
  kind      ProjectKind
  imageUrl  String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([kind, sortOrder])
}
