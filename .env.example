# Les variables peuvent être dans .env.local (Next.js).
# Le CLI Prisma ne lit pas .env.local tout seul : utilise `npm run db:push`
# (charge la cascade .env / .env.* / .env.local via dotenv-cli).

# PostgreSQL (Neon, etc.) — métadonnées + URLs des images uniquement
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# iron-session : chaîne aléatoire d’au moins 32 caractères
SESSION_SECRET="remplace-par-une-chaine-longue-aleatoire-min-32-chars"

# Mot de passe admin : hash bcrypt encodé en base64 (obligatoire avec Next.js,
# car les $ dans un hash brut sont mangés par l’expansion des variables .env).
# npm run hash-admin-password
ADMIN_PASSWORD_HASH_B64=

# (Optionnel, souvent cassé par Next — ne pas utiliser seul)
# ADMIN_PASSWORD_HASH=

# Stockage fichiers : Vercel Blob. Token depuis Storage → Blob → projet.
BLOB_READ_WRITE_TOKEN=
# Store « private » (défaut) : les images passent par /api/blob-file/...
# Store « public » côté Vercel : mets BLOB_ACCESS=public pour enregistrer l’URL directe.
# BLOB_ACCESS=public
